{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20
    },
    "configurePresets": [
        {
            "name": "ninja-debug-with-tests",
            "displayName": "Debug - With tests",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/debug-with-tests",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "SABRE_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "ninja-release-with-tests",
            "displayName": "Release - With tests",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/release-with-tests",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "SABRE_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "ninja-release-without-tests",
            "displayName": "Release - Without tests",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/release-without-tests",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "SABRE_BUILD_TESTS": "OFF"
            }
        }
    ]
}